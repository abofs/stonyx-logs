{
  "name": "@stonyx/logs",
  "version": "1.0.1-beta.12",
  "description": "Simplified logging for node applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./color": {
      "types": "./dist/color.d.ts",
      "default": "./dist/color.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "pnpm build && pnpm build:test && qunit 'dist-test/test/unit/**/*-test.js'",
    "lint": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abofs/stonyx-logs.git"
  },
  "keywords": [
    "log",
    "logging",
    "color-coding",
    "stonyx",
    "history",
    "documentation",
    "document",
    "chalk",
    "clean-output",
    "terminal",
    "debug"
  ],
  "author": "Stone Costa",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/abofs/stonyx-logs/issues"
  },
  "homepage": "https://github.com/abofs/stonyx-logs#readme",
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/qunit": "^2.19.13",
    "@types/sinon": "^21.0.1",
    "eslint": "^8.27.0",
    "eslint-plugin-node": "^11.1.0",
    "qunit": "^2.19.3",
    "sinon": "^17.0.0",
    "typescript": "^5.8.3"
  }
}
